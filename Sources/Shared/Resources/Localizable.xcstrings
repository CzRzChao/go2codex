          }
        }
      }
    },
    "Session Placement": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "会话打开方式"
          }
        }
      }
    },
    "New Tab": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "新标签页"
          }
        }
      }
    },
    "New Window": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "新窗口"
          }
        }
      }
    },
    "Finder Toolbar": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Finder 工具栏"
          }
        }
      }
    },
    "Status": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "状态"
          }
        }
      }
    },
    "Unavailable": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "不可用"
          }
        }
      }
    },
    "Checking…": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "正在检查…"
          }
        }
      }
    },
    "Installed": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已安装"
          }
        }
      }
    },
    "Not Installed": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "未安装"
          }
        }
      }
    },
    "Needs Repair": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "需要修复"
          }
        }
      }
    },
    "Manual Setup Required": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "需要手动设置"
          }
        }
      }
    },
    "Settings could not be saved. Try again.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法保存设置，请重试。"
          }
        }
      }
    },
    "Your choices are saved before Finder installation begins.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "开始安装到 Finder 前，会先保存你的选择。"
          }
        }
      }
    },
    "Your choices are saved before manual Finder setup begins.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "开始手动设置 Finder 前，会先保存你的选择。"
          }
        }
      }
    },
    "Complete Setup and Install in Finder": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "完成设置并安装到 Finder"
          }
        }
      }
    },
    "Complete Setup and Show Manual Setup": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "完成设置并显示手动安装步骤"
          }
        }
      }
    },
    "Choose a default target and terminal host to continue.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请选择默认目标和终端后继续。"
          }
        }
      }
    },
    "Automatic Finder setup is unavailable. Use the manual Command-drag setup instead.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "自动设置 Finder 当前不可用。请改用按住 Command 拖入的手动方式。"
          }
        }
      }
    },
    "Finder toolbar setup could not be completed.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法完成 Finder 工具栏设置。"
          }
        }
      }
    },
    "Install in Finder": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "安装到 Finder"
          }
        }
      }
    },
    "Uninstall from Finder": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "从 Finder 卸载"
          }
        }
      }
    },
    "Repair in Finder": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在 Finder 中修复"
          }
        }
      }
    },
    "Show Manual Setup": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "显示手动安装步骤"
          }
        }
      }
    },
    "Show Removal Instructions": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "显示手动移除步骤"
          }
        }
      }
    },
    "Settings Need Attention": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "设置需要处理"
          }
        }
      }
    },
    "Go2Codex couldn't read its saved settings. No launch action will run.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Go2Codex 无法读取已保存的设置，因此不会执行任何启动操作。"
          }
        }
      }
    },
    "Open Automation Settings": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "打开“自动化”设置"
          }
        }
      }
    },
    "Copy Diagnostics": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "复制诊断信息"
          }
        }
      }
    },
    "Cancel": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "取消"
          }
        }
      }
    },
    "OK": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "好"
          }
        }
      }
    },
    "Option-click is reserved by Finder. Use Shift-click.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Option 点击已被 Finder 占用，请使用 Shift 点击。"
          }
        }
      }
    },
    "Target Picker could not be shown": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法显示目标选择菜单"
          }
        }
      }
    },
    "Try again and keep holding Shift until the menu is visible.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请重试，并持续按住 Shift，直到菜单稳定显示。"
          }
        }
      }
    },
    "The original Finder folder is no longer available": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "原 Finder 文件夹已不可用"
          }
        }
      }
    },
    "Finder is unavailable": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Finder 不可用"
          }
        }
      }
    },
    "This Finder location cannot be opened": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法打开此 Finder 位置"
          }
        }
      }
    },
    "This Finder view is not a folder": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当前 Finder 位置不是实际文件夹"
          }
        }
      }
    },
    "Open a regular folder in Finder, then try again. Smart folders such as Recents cannot be used as a workspace.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请先在 Finder 中打开一个普通文件夹再重试。“最近使用”等智能文件夹不能作为工作目录。"
          }
        }
      }
    },
    "The Finder folder is not accessible": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法访问 Finder 中的文件夹"
          }
        }
      }
    },
    "The selected target is unavailable": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "所选目标不可用"
          }
        }
      }
    },
    "Go2Codex could not complete the handoff": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Go2Codex 无法完成交接"
          }
        }
      }
    },
    "Go2Codex could not determine whether iTerm has a window": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Go2Codex 无法判断 iTerm 是否有窗口"
          }
        }
      }
    },
    "No terminal session was opened. Try again, or choose New Window in Go2Codex Settings.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "未打开任何终端会话。请重试，或在 Go2Codex 设置中选择“新窗口”。"
          }
        }
      }
    },
    "Accessibility permission is required for Terminal tabs": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Terminal 标签页需要“辅助功能”权限"
          }
        }
      }
    },
    "Automation permission is required for Terminal tabs": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Terminal 标签页需要“自动化”权限"
          }
        }
      }
    },
    "Go2Codex could not create a Terminal tab": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Go2Codex 无法创建 Terminal 标签页"
          }
        }
      }
    },
    "Go2Codex could not start the CLI in the Terminal tab": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Go2Codex 无法在 Terminal 标签页中启动 CLI"
          }
        }
      }
    },
    "The Terminal tab was created, but its TTY did not become ready, so no command was submitted. Close the empty tab and try again, or choose New Window in Go2Codex Settings.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Terminal 标签页已创建，但其 TTY 未就绪，因此未提交任何命令。请关闭空标签页后重试，或在 Go2Codex 设置中选择“新窗口”。"
          }
        }
      }
    },
    "A Terminal tab was created, but Go2Codex could not safely identify it, so no command was submitted. Close the empty tab and try again, or choose New Window in Go2Codex Settings.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Terminal 标签页已创建，但 Go2Codex 无法安全识别它，因此未提交任何命令。请关闭空标签页后重试，或在 Go2Codex 设置中选择“新窗口”。"
          }
        }
      }
    },
    "No command was submitted. Try again, or choose New Window in Go2Codex Settings.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "未提交任何命令。请重试，或在 Go2Codex 设置中选择“新窗口”。"
          }
        }
      }
    },
    "Go2Codex could not start the iTerm session": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Go2Codex 无法启动 iTerm 会话"
          }
        }
      }
    },
    "No iTerm session was opened because the account login shell is unavailable or unsupported. Check the login shell in System Settings, then try again.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "由于账户登录 shell 不可用或不受支持，未打开 iTerm 会话。请在“系统设置”中检查登录 shell，然后重试。"
          }
        }
      }
    },
    "Go2Codex could not confirm the iTerm session": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Go2Codex 无法确认 iTerm 会话"
          }
        }
      }
    },
    "iTerm may already have created the requested session. Check iTerm before trying again to avoid opening a duplicate session.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "iTerm 可能已经创建了请求的会话。请先检查 iTerm 再重试，以免打开重复会话。"
          }
        }
      }
    },
    "Terminal New Tab needs the current Go2CodexLauncher in Accessibility. If an older Go2CodexLauncher entry exists, remove it. Then choose Locate Current Launcher, add the revealed launcher to Accessibility, turn it on, and try again. Unsigned preview updates can invalidate an earlier entry.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Terminal 新标签页需要在“辅助功能”中启用当前的 Go2CodexLauncher。如果存在旧的 Go2CodexLauncher 条目，请先将它删除。然后选择“定位当前 Launcher”，把显示的 Launcher 添加到“辅助功能”并开启，再重试。未签名预览版升级后，早先的条目可能会失效。"
          }
        }
      }
    },
    "Allow Go2Codex to control System Events in System Settings > Privacy & Security > Automation, then try again.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请在“系统设置”>“隐私与安全性”>“自动化”中允许 Go2Codex 控制“系统事件”，然后重试。"
          }
        }
      }
    },
    "Allow Go2Codex to control Finder in System Settings > Privacy & Security > Automation, then try again.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请在“系统设置”>“隐私与安全性”>“自动化”中允许 Go2Codex 控制 Finder，然后重试。"
          }
        }
      }
    },
    "Allow Go2Codex to control Terminal in System Settings > Privacy & Security > Automation, then try again.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请在“系统设置”>“隐私与安全性”>“自动化”中允许 Go2Codex 控制 Terminal，然后重试。"
          }
        }
      }
    },
    "Allow Go2Codex to control iTerm2 in System Settings > Privacy & Security > Automation, then try again.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请在“系统设置”>“隐私与安全性”>“自动化”中允许 Go2Codex 控制 iTerm2，然后重试。"
          }
        }
      }
    },
    "No alternate target was used. You can copy sanitized diagnostics for troubleshooting.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "未使用其他目标。你可以复制已脱敏的诊断信息来排查问题。"
          }
        }
      }
    },
    "Open Automation Settings manually": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "手动打开“自动化”设置"
          }
        }
      }
    },
    "Open Accessibility Settings": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "打开“辅助功能”设置"
          }
        }
      }
    },
    "Locate Current Launcher": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "定位当前 Launcher"
          }
        }
      }
    },
    "Current Launcher could not be located": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法定位当前 Launcher"
          }
        }
      }
    },
    "Current Launcher is selected in Finder": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已在 Finder 中选中当前 Launcher"
          }
        }
      }
    },
    "Keep the Finder window open. In Accessibility, remove any older Go2CodexLauncher entry, then add the selected launcher and turn it on.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请保持 Finder 窗口打开。在“辅助功能”中删除旧的 Go2CodexLauncher 条目，再添加已选中的 Launcher 并将它开启。"
          }
        }
      }
    },
    "Open Go2Codex.app in Finder, choose Show Package Contents, then open Contents > Helpers to find Go2CodexLauncher.app.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请在 Finder 中打开 Go2Codex.app，选择“显示包内容”，然后打开 Contents > Helpers 找到 Go2CodexLauncher.app。"
          }
        }
      }
    },
    "Open Privacy Settings manually": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "手动打开隐私设置"
          }
        }
      }
    },
    "Open System Settings, choose Privacy & Security, then enable Go2Codex in the requested Automation or Accessibility section.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "打开“系统设置”，选择“隐私与安全性”，然后在提示的“自动化”或“辅助功能”中启用 Go2Codex。"
          }
        }
      }
    },
    "Open System Settings, choose Privacy & Security, then Automation, and enable Go2Codex for Finder or your selected terminal.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "打开“系统设置”，选择“隐私与安全性”，再选择“自动化”，并允许 Go2Codex 控制 Finder 或你选择的终端。"
          }
        }
      }
    },
    "Close Probe": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "关闭探针"
          }
        }
      }
    },
    "Install Go2Codex in Finder?": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "要将 Go2Codex 安装到 Finder 吗？"
          }
        }
      }
    },
    "Repair Go2Codex in Finder?": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "要修复 Finder 中的 Go2Codex 吗？"
          }
        }
      }
    },
    "Remove Go2Codex from Finder?": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "要从 Finder 中移除 Go2Codex 吗？"
          }
        }
      }
    },
    "Experimental setup will update your private Finder toolbar preferences and restart Finder. Go2Codex creates a recovery journal first and preserves unrelated toolbar items.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "实验性安装将修改你的 Finder 私有工具栏设置并重启 Finder。Go2Codex 会先创建恢复日志，并保留无关的工具栏项目。"
          }
        }
      }
    },
    "Experimental repair will update the existing Go2Codex toolbar item and restart Finder. Go2Codex creates a recovery journal first and preserves unrelated toolbar items.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "实验性修复将更新现有的 Go2Codex 工具栏项目并重启 Finder。Go2Codex 会先创建恢复日志，并保留无关的工具栏项目。"
          }
        }
      }
    },
    "Experimental removal will remove only the verified Go2Codex toolbar item and restart Finder. Go2Codex creates a recovery journal first.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "实验性移除只会删除已验证的 Go2Codex 工具栏项目并重启 Finder。Go2Codex 会先创建恢复日志。"
          }
        }
      }
    },
